# Oracle
ORACLE_HOME=/u01/app/oracle/product/19.3.0.0/dbhome_1
GG_HOME=/u01/app/oracle/product/19.1.0.0/gghome_1

# Patching
PATCH_BASE_DIR=/oraprd/oracle_patch
PATCH_ID=38273545          # top folder holding DBRU + OJVM subfolders
LATEST_OPATCH_ZIP=/oraprd/oracle_patch/p6880880_190000_Linux-x86-64.zip   # e.g., /oraprd/opatch/p6880880_190000_Linux-x86-64.zip
#LATEST_OPATCH_ZIP=         # optional, path to OPatch zip if you update OPatch

# Logging
LOGDIR=/oraprd/patching_logs
MASTER_LOG=$LOGDIR/Patching_$(date +%Y%m%d-%H%M).log
STEP_LOG=$LOGDIR/Step_$(date +%Y%m%d-%H%M).log

# Backup
BACKUP_DIR=/oraprd/backups

# Timings (optional tuning)
SETTLE_WAIT_SECONDS=15
POLL_INTERVAL=5
TIMEOUT_SECONDS=600

